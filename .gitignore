# Local secrets / environment
.env
.env.*
*.pem
*.key
*.token

# Dependencies / caches
node_modules/
.npm/
.cache/
coverage/

# OS/editor noise
.DS_Store
*.swp
*.swo

# Python cache from ad-hoc helpers
__pycache__/
*.pyc

